# Test Environment Variables
# Copy this to .env.test and fill in test-specific values

# Database
TEST_DATABASE_URL=postgresql://localhost:5432/lucaagent_test
DATABASE_URL=postgresql://localhost:5432/lucaagent_test

# Session
SESSION_SECRET=test-session-secret-change-in-production

# Disable external services in tests
SKIP_AI_PROVIDERS=true
SKIP_VIRUS_SCAN=true
SKIP_EMAIL_SENDING=true

# Test mode flags
NODE_ENV=test
CI=false

# Mock API keys (not real, for testing only)
OPENAI_API_KEY=sk-test-mock-key
AZURE_OPENAI_API_KEY=test-azure-key
ANTHROPIC_API_KEY=test-anthropic-key
GOOGLE_AI_API_KEY=test-google-key

# Encryption (test key, not secure)
ENCRYPTION_KEY=test-encryption-key-32-characters-long

# Redis (optional for tests, can use in-memory)
REDIS_URL=redis://localhost:6379/1
