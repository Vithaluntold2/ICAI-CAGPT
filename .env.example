# ============================================================
# ICAI CA GPT — Environment Variables Reference
# ============================================================
# Copy this to .env and fill in your values.
# For production (AWS), use AWS Secrets Manager — do NOT
# commit .env files with real secrets.
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# AWS RDS PostgreSQL connection string
# Format: postgresql://user:password@your-rds-endpoint.rds.amazonaws.com:5432/icai_cagpt?ssl=true
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/icai_cagpt

# Session secret — generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_64_CHAR_HEX

# ── AI PROVIDERS (at least one required) ────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
PERPLEXITY_API_KEY=

# ── AWS SERVICES ─────────────────────────────────────────────

# IAM credentials (use instance role on ECS — avoid hardcoding)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# S3 bucket for file uploads
AWS_S3_BUCKET=icai-cagpt-uploads

# KMS key for encryption at rest
AWS_KMS_KEY_ID=

# Key vault provider: env | aws-kms | azure-keyvault
# Set to aws-kms for production AWS deployments
KEY_VAULT_PROVIDER=aws-kms

# ── DATABASE (AWS RDS specific) ──────────────────────────────

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30000
DB_SSL=true

# ── REDIS (AWS ElastiCache) ──────────────────────────────────

REDIS_URL=redis://your-elasticache-endpoint:6379

# ── OPTIONAL FEATURES ────────────────────────────────────────

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Payments (Cashfree — optional alternative)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry error tracking
SENTRY_DSN=

# Feature flags
ENABLE_DEEP_RESEARCH=false
ENABLE_EXPERT_ROUNDTABLE=false
ENABLE_KNOWLEDGE_GRAPH=false
ENABLE_EXPERIMENTAL_AGENTS=false

# Admin setup key — generate with: openssl rand -hex 32
ADMIN_SETUP_KEY=CHANGE_ME_32_CHAR_HEX

# ── MONITORING ───────────────────────────────────────────────

LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ALLOWED_ORIGINS=https://cagpt.icai.org

# Development overrides (copy to .env.local)
# NODE_ENV=development
# ALLOWED_ORIGINS=http://localhost:5000
# LOG_LEVEL=debug
# KEY_VAULT_PROVIDER=env
# Enable the dynamic chat + whiteboard UX (Phase 9+).
# Default: false
ENABLE_WHITEBOARD_V2=false

# Enable per-agent POV synthesizer in roundtable. Off by default; flip to 'true'
# after migration 0007 has been applied to your DB. When on, each panel agent
# gets a persistent POV doc (agent_pov_documents) updated by a background
# synthesizer subworker after every turn.
ROUNDTABLE_SYNTHESIZER_ENABLED=false
