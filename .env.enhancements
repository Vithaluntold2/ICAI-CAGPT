# Environment Variables for Enhancements
# Copy this to your .env file and fill in the values

# ============================================
# EXISTING VARIABLES (Keep These)
# ============================================
DATABASE_URL=postgresql://...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# ... (all your existing vars)

# ============================================
# NEW: ERROR TRACKING & MONITORING
# ============================================
# Sentry for error tracking and performance monitoring
# Sign up at: https://sentry.io (Free tier available)
SENTRY_DSN=https://xxx@sentry.io/xxx
RELEASE_VERSION=1.0.0

# ============================================
# NEW: CACHING (RECOMMENDED)
# ============================================
# Upstash Redis for distributed caching
# Sign up at: https://upstash.com (Free tier: 10,000 requests/day)
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=xxx

# ============================================
# NEW: VECTOR SEARCH (OPTIONAL)
# ============================================
# Pinecone for semantic search and RAG
# Sign up at: https://www.pinecone.io (Free tier: 1 index, 100K vectors)
PINECONE_API_KEY=xxx
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=lucaagent-docs

# ============================================
# NEW: AI OBSERVABILITY (OPTIONAL)
# ============================================
# LangSmith for AI debugging and tracing
# Sign up at: https://smith.langchain.com (Free tier available)
LANGCHAIN_API_KEY=lsv2_xxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=lucaagent

# ============================================
# NEW: RERANKING (OPTIONAL)
# ============================================
# Cohere for hybrid search reranking
# Sign up at: https://cohere.com (Free tier: 100 calls/minute)
COHERE_API_KEY=xxx

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable new features gradually
FEATURE_LANGCHAIN=false          # Use LangChain orchestration
FEATURE_VECTOR_SEARCH=false      # Use Pinecone vector search
FEATURE_ADVANCED_CACHING=true    # Use Redis caching
FEATURE_RERANKING=false          # Use Cohere reranking

# ============================================
# CONFIGURATION
# ============================================
# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Cache TTLs (in seconds)
CACHE_TTL_AI_RESPONSE=3600       # 1 hour
CACHE_TTL_USER_SESSION=1800      # 30 minutes
CACHE_TTL_PROVIDER_HEALTH=60     # 1 minute

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000       # 1 minute
RATE_LIMIT_MAX_REQUESTS=100      # 100 requests per minute

# AI Configuration
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4000
AI_STREAMING=true

# ============================================
# DEPLOYMENT
# ============================================
NODE_ENV=production              # development | production
PORT=3000

# ============================================
# INSTRUCTIONS
# ============================================
#
# REQUIRED (Immediate):
# 1. DATABASE_URL - Your existing database
# 2. OPENAI_API_KEY - Your existing OpenAI key
# 3. ANTHROPIC_API_KEY - Your existing Anthropic key
#
# RECOMMENDED (Week 1):
# 4. SENTRY_DSN - For error tracking (free tier)
# 5. UPSTASH_REDIS_URL + TOKEN - For caching (free tier)
#    → Set FEATURE_ADVANCED_CACHING=true
#
# OPTIONAL (Week 2+):
# 6. PINECONE_API_KEY - For vector search (free tier)
#    → Set FEATURE_VECTOR_SEARCH=true
# 7. LANGCHAIN_API_KEY - For AI observability (free tier)
# 8. COHERE_API_KEY - For reranking (free tier)
#    → Set FEATURE_RERANKING=true
#
# ============================================
# GETTING STARTED
# ============================================
#
# Step 1: Copy this file
#   cp .env.enhancements .env
#
# Step 2: Fill in required values
#   - Keep existing DATABASE_URL, API keys, etc.
#   - Add new ones as you implement features
#
# Step 3: Start with free tiers
#   - Sentry: https://sentry.io
#   - Upstash: https://upstash.com
#   - All have generous free tiers!
#
# Step 4: Enable features gradually
#   - Start with FEATURE_ADVANCED_CACHING=true
#   - Add others as you implement them
#
# ============================================
# COST ESTIMATES (With Free Tiers)
# ============================================
#
# Free tier limits:
# - Sentry: 5,000 errors/month
# - Upstash Redis: 10,000 requests/day
# - Pinecone: 1 index, 100K vectors
# - LangSmith: 5,000 traces/month
# - Cohere: 100 calls/minute
#
# Paid tiers (if you exceed free):
# - Sentry: $26/month (50K errors)
# - Upstash: $10/month (1M requests/day)
# - Pinecone: $70/month (1M queries)
# - LangSmith: $99/month (unlimited)
# - Cohere: $0.001 per rerank call
#
# Total: ~$0/month (free tier) → $205/month (paid)
#
# ============================================
